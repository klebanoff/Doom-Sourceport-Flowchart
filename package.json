{
  "name": "doom-sourceport-flowchart",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun --hot index.ts",
    "build": "bun build ./src/main.ts --outdir=dist --minify && bun scripts/copyStatic.ts",
    "typecheck": "bun x tsc --noEmit",
    "validate:data": "bun scripts/validateData.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "canvg": "^4.0.3"
  }
}
