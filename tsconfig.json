{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["bun-types"],
    "moduleDetection": "force",
    "jsx": "react",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "skipLibCheck": true
  },
  "include": [
    "src",
    "index.ts",
    "global.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/*"
  ]
}
